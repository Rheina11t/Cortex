# ============================================================================
# Family Brain – Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Required variables are marked with (REQUIRED).
# Optional variables have sensible defaults.
# ============================================================================

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# ── OpenAI (REQUIRED for embeddings) ─────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_EMBEDDING_BASE_URL="https://api.openai.com/v1"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_BACKEND="openai"

# ── LLM Backend ──────────────────────────────────────────────────────────
# Options: openai | anthropic
# OpenAI uses gpt-4.1-mini by default. Anthropic uses claude-3-5-haiku.
LLM_BACKEND="openai"
LLM_MODEL="gpt-4.1-mini"

# ── Anthropic (required when LLM_BACKEND=anthropic) ─────────────────────
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY="sk-ant-api03-..."

# ── Telegram Capture Layer (REQUIRED for Telegram bot) ───────────────────
# 1. Open Telegram and message @BotFather
# 2. Send /newbot and follow the prompts
# 3. Copy the token here
TELEGRAM_BOT_TOKEN="123456789:AAF..."
# Legacy: comma-separated user IDs (superseded by FAMILY_MEMBER_N_ID)
# TELEGRAM_ALLOWED_USER_IDS="123456789,987654321"

# ── Family Members ───────────────────────────────────────────────────────
# Define authorised family members. Only these users can interact with the bot.
# Each memory is tagged with the family member's name in metadata.
# To find your Telegram user ID, message @userinfobot on Telegram.
#
# Add more members by incrementing the number (up to 20).
FAMILY_MEMBER_1_ID=
FAMILY_MEMBER_1_NAME=
FAMILY_MEMBER_2_ID=
FAMILY_MEMBER_2_NAME=

# ── Google Vision API (optional – for photo/document OCR) ────────────────
# Enables text extraction from photos and PDF documents sent to the bot.
# Without this, photos are stored with a basic description.
#
# Option 1: Service account JSON key file (recommended for production)
#   1. Go to: https://console.cloud.google.com/apis/credentials
#   2. Create a service account and download the JSON key
#   3. Enable the Vision API
GOOGLE_VISION_KEY_PATH=""
#
# Option 2: API key (simpler, for personal use)
#   1. Go to: https://console.cloud.google.com/apis/credentials
#   2. Create an API key and restrict it to Vision API
GOOGLE_VISION_API_KEY=""

# ── Email Capture (optional – for Gmail IMAP ingestion) ──────────────────
# Polls a Gmail inbox and stores email content as memories.
#
# For Gmail, you need an App Password:
#   1. Enable 2FA on your Google account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Generate an app password for "Mail"
FAMILY_BRAIN_EMAIL=""
FAMILY_BRAIN_EMAIL_PASSWORD=""
EMAIL_IMAP_HOST="imap.gmail.com"
EMAIL_IMAP_PORT=993
EMAIL_POLL_INTERVAL_SECONDS=300
# Comma-separated list of allowed sender addresses (empty = all senders)
EMAIL_ALLOWED_SENDERS=""

# ── MCP Server ───────────────────────────────────────────────────────────
# Transport: stdio (local), http (remote, recommended), sse (legacy)
MCP_TRANSPORT="stdio"
# MCP_HOST="0.0.0.0"
# MCP_PORT=8321

# Static bearer token for Manus, Cursor, Claude Desktop.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# MCP_AUTH_TOKEN=""

# ── OAuth 2.0 (for ChatGPT and other OAuth-capable MCP clients) ─────────
# The password you enter on the consent screen to authorize a client.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# OAUTH_USER_PASSWORD=""
# OAUTH_SERVER_URL=""
# OAUTH_TOKEN_TTL=86400

# ── Daily Digest ─────────────────────────────────────────────────────────
# Telegram user IDs to receive the daily digest (comma-separated).
# Defaults to all family member IDs if not set.
# DIGEST_RECIPIENT_IDS=""

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"

# ============================================================================
# SQL Migrations (run in order in Supabase SQL Editor)
# ============================================================================
# 001_create_memories.sql         – Core memories table with pgvector
# 002_add_updated_at.sql          – updated_at column + trigger
# 003_household_knowledge.sql     – household_items + household_vendors
# 004_family_events.sql           – family_events table
# 005_home_maintenance.sql        – maintenance_tasks + maintenance_logs
# 006_vehicle_management.sql      – vehicles + vehicle_service_logs
# 007_health_wellness.sql         – health_records + medications + medical_appointments
# 008_financial_tracker.sql       – financial_accounts + financial_transactions + budgets
# 009_job_hunt_crm.sql            – jh_contacts + jh_applications + jh_interviews
# ============================================================================
