# ============================================================================
# Family Brain – Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Required variables are marked with (REQUIRED).
# Optional variables have sensible defaults.
# ============================================================================

# ── Supabase (REQUIRED) ──────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# ── OpenAI (REQUIRED for embeddings) ─────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_EMBEDDING_BASE_URL="https://api.openai.com/v1"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_BACKEND="openai"

# ── LLM Backend ──────────────────────────────────────────────────────────
# Options: openai | anthropic
# OpenAI uses gpt-4.1-mini by default. Anthropic uses claude-3-5-haiku.
LLM_BACKEND="openai"
LLM_MODEL="gpt-4.1-mini"

# ── Anthropic (required when LLM_BACKEND=anthropic) ─────────────────────
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY="sk-ant-api03-..."

# ── Telegram Capture Layer (REQUIRED for Telegram bot) ───────────────────
# 1. Open Telegram and message @BotFather
# 2. Send /newbot and follow the prompts
# 3. Copy the token here
TELEGRAM_BOT_TOKEN="123456789:AAF..."
# Legacy: comma-separated user IDs (superseded by FAMILY_MEMBER_N_ID)
# TELEGRAM_ALLOWED_USER_IDS="123456789,987654321"

# ── Family Members ───────────────────────────────────────────────────────
# Define authorised family members. Only these users can interact with the bot.
# Each memory is tagged with the family member's name in metadata.
# To find your Telegram user ID, message @userinfobot on Telegram.
#
# Add more members by incrementing the number (up to 20).
FAMILY_MEMBER_1_ID=
FAMILY_MEMBER_1_NAME=
FAMILY_MEMBER_2_ID=
FAMILY_MEMBER_2_NAME=

# ── WhatsApp Transport Layer ────────────────────────────────────────────
# FamilyBrain supports two WhatsApp transports:
#   1. Meta Cloud API (recommended) — set USE_META_API=true
#   2. Twilio (legacy fallback)     — set USE_META_API=false or omit
#
# Feature flag: set to "true" to use Meta Cloud API, "false" for Twilio.
USE_META_API="false"

# ── Meta WhatsApp Cloud API (REQUIRED when USE_META_API=true) ───────────
# Setup steps:
#   1. Create a Meta Business App at https://developers.facebook.com
#   2. Add the WhatsApp product to your app
#   3. In WhatsApp > API Setup, get your Phone Number ID and generate a
#      permanent access token (System User token recommended for production)
#   4. Configure your webhook URL:
#      POST https://your-railway-url.up.railway.app/whatsapp
#      Subscribed fields: messages
#   5. Set WHATSAPP_VERIFY_TOKEN to any secret string and use the same
#      value when registering the webhook in Meta's dashboard
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="my-secret-verify-token"

# ── Twilio WhatsApp (REQUIRED when USE_META_API=false) ──────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Set to true to skip Twilio signature validation in development/testing
# TWILIO_SKIP_SIGNATURE_VALIDATION=false

# ── Google Calendar OAuth (REQUIRED for calendar sync) ───────────────────
# Google OAuth credentials for Calendar API access.
# Client type: Web Application (not "installed") — redirect URI must be public HTTPS.
#
# Steps:
#   1. Go to: https://console.cloud.google.com/apis/credentials
#   2. Create an OAuth 2.0 Client ID of type "Web application"
#   3. Add your Railway URL + /gcal/callback as an Authorized Redirect URI:
#      e.g. https://cortex-production.up.railway.app/gcal/callback
#   4. Enable the Google Calendar API in your project
GOOGLE_CALENDAR_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CALENDAR_CLIENT_SECRET=""  # REQUIRED: Set this to your Google OAuth client secret. NEVER commit real secrets.
# Static fallback refresh token (Dan's existing setup — backward compat)
GOOGLE_CALENDAR_REFRESH_TOKEN=""
GOOGLE_CALENDAR_ID="primary"

# ── FamilyBrain Base URL (REQUIRED for OAuth web flow) ───────────────────
# The public HTTPS URL of the bot (e.g. your Railway deployment URL).
# Used to construct the OAuth callback URL and calendar connect links.
FAMILYBRAIN_BASE_URL="https://cortex-production.up.railway.app"
# Defaults to {FAMILYBRAIN_BASE_URL}/gcal/callback if not set.
# GOOGLE_CALENDAR_OAUTH_REDIRECT_URI="https://cortex-production.up.railway.app/gcal/callback"

# ── Stripe Billing (REQUIRED for subscription payments) ──────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
# The Stripe Price ID for the monthly subscription (e.g. price_...).
# Create a recurring monthly price in the Stripe dashboard.
# Default price is £4.99/month — configure the actual amount in Stripe.
STRIPE_PRICE_ID="price_..."
# Webhook signing secret — from Stripe Dashboard -> Webhooks -> Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."
# Stripe webhook events to enable in the Stripe dashboard:
#   checkout.session.completed
#   customer.subscription.deleted
# Webhook URL: {FAMILYBRAIN_BASE_URL}/stripe/webhook

# ── Google Vision API (optional – for photo/document OCR) ────────────────
# Enables text extraction from photos and PDF documents sent to the bot.
# Without this, photos are stored with a basic description.
#
# Option 1: Service account JSON key file (recommended for production)
#   1. Go to: https://console.cloud.google.com/apis/credentials
#   2. Create a service account and download the JSON key
#   3. Enable the Vision API
GOOGLE_VISION_KEY_PATH=""
#
# Option 2: API key (simpler, for personal use)
#   1. Go to: https://console.cloud.google.com/apis/credentials
#   2. Create an API key and restrict it to Vision API
GOOGLE_VISION_API_KEY=""

# ── Mailgun Inbound Email (optional – for email forwarding to FamilyBrain) ──
# Allows families to forward emails to {family_id}@familybrain.co.uk.
# The bot processes the email and attachments, stores memories, and notifies the family.
#
# Setup steps:
#   1. Create a Mailgun account at https://www.mailgun.com
#   2. Add familybrain.co.uk as a domain (verify DNS records)
#   3. Create a catch-all inbound route:
#      match_recipient(".*@familybrain.co.uk") -> forward to:
#      https://your-railway-url.up.railway.app/webhook/email-inbound
#   4. Copy the HTTP webhook signing key from Mailgun Dashboard -> Webhooks
#   5. Add the signing key to Railway env vars as MAILGUN_WEBHOOK_SIGNING_KEY
MAILGUN_API_KEY=""
MAILGUN_WEBHOOK_SIGNING_KEY=""
MAILGUN_DOMAIN="familybrain.co.uk"

# ── Email Capture (optional – for Gmail IMAP ingestion) ──────────────────
# Polls a Gmail inbox and stores email content as memories.
#
# For Gmail, you need an App Password:
#   1. Enable 2FA on your Google account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Generate an app password for "Mail"
FAMILY_BRAIN_EMAIL=""
FAMILY_BRAIN_EMAIL_PASSWORD=""
EMAIL_IMAP_HOST="imap.gmail.com"
EMAIL_IMAP_PORT=993
EMAIL_POLL_INTERVAL_SECONDS=300
# Comma-separated list of allowed sender addresses (empty = all senders)
EMAIL_ALLOWED_SENDERS=""

# ── MCP Server ───────────────────────────────────────────────────────────
# Transport: stdio (local), http (remote, recommended), sse (legacy)
MCP_TRANSPORT="stdio"
# MCP_HOST="0.0.0.0"
# MCP_PORT=8321

# Static bearer token for Manus, Cursor, Claude Desktop.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# MCP_AUTH_TOKEN=""

# ── OAuth 2.0 (for ChatGPT and other OAuth-capable MCP clients) ─────────
# The password you enter on the consent screen to authorize a client.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# OAUTH_USER_PASSWORD=""
# OAUTH_SERVER_URL=""
# OAUTH_TOKEN_TTL=86400

# ── Daily Digest ─────────────────────────────────────────────────────────
# Telegram user IDs to receive the daily digest (comma-separated).
# Defaults to all family member IDs if not set.
# DIGEST_RECIPIENT_IDS=""

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"

# ============================================================================
# SQL Migrations (run in order in Supabase SQL Editor)
# ============================================================================
# 001_create_memories.sql         – Core memories table with pgvector
# 002_add_updated_at.sql          – updated_at column + trigger
# 003_household_knowledge.sql     – household_items + household_vendors
# 004_family_events.sql           – family_events table
# 005_home_maintenance.sql        – maintenance_tasks + maintenance_logs
# 006_vehicle_management.sql      – vehicles + vehicle_service_logs
# 007_health_wellness.sql         – health_records + medications + medical_appointments
# 008_financial_tracker.sql       – financial_accounts + financial_transactions + budgets
# 009_job_hunt_crm.sql            – jh_contacts + jh_applications + jh_interviews
# 010_onboarding.sql               – families + whatsapp_members tables
# 011_gcal_oauth.sql               – gcal_connect_tokens table + google_refresh_token columns
# 022_stripe_billing.sql           – Stripe billing columns on families table
# ============================================================================
